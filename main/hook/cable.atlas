images {
  image: "/assets/images/cable.png"
  sprite_trim_mode: SPRITE_TRIM_MODE_OFF
}
animations {
  id: "default"
  images {
    image: "/assets/images/cable.png"
    sprite_trim_mode: SPRITE_TRIM_MODE_OFF
  }
  playback: PLAYBACK_NONE
  fps: 1
  flip_horizontal: 0
  flip_vertical: 0
}
margin: 0
inner_padding: 0
extrude_borders: 0
