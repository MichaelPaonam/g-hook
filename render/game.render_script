local DISPLAY_WIDTH = tonumber(sys.get_config("display.width")) or 960
local DISPLAY_HEIGHT = tonumber(sys.get_config("display.height")) or 640
local CAMERA_ZOOM = 1.0 -- >1 = zoomed in, shows less of the world

local function fit_viewport(window_w, window_h)
	local scale = math.min(window_w / DISPLAY_WIDTH, window_h / DISPLAY_HEIGHT)
	local viewport_w = math.floor(DISPLAY_WIDTH * scale + 0.5)
	local viewport_h = math.floor(DISPLAY_HEIGHT * scale + 0.5)
	local viewport_x = math.floor((window_w - viewport_w) * 0.5)
	local viewport_y = math.floor((window_h - viewport_h) * 0.5)
	return viewport_x, viewport_y, viewport_w, viewport_h
end

function init(self)
	self.bg_pred      = render.predicate({"background"})
	self.tile_pred    = render.predicate({"tile"})
	self.cable_pred   = render.predicate({"cable"})
	self.sprite_pred  = render.predicate({"sprite"})
	self.gui_pred     = render.predicate({"gui"})
	self.text_pred    = render.predicate({"text"})
	self.particle_pred = render.predicate({"particle"})

	self.clear_color = vmath.vector4(0.08, 0.08, 0.12, 1)
	self.camera_pos = vmath.vector3(0, 0, 0)
end

function update(self)
	render.set_depth_mask(true)
	render.set_stencil_mask(0xff)
	render.clear({
		[render.BUFFER_COLOR_BIT] = self.clear_color,
		[render.BUFFER_DEPTH_BIT] = 1,
		[render.BUFFER_STENCIL_BIT] = 0
	})

	local window_w = render.get_window_width()
	local window_h = render.get_window_height()
	if window_w == 0 or window_h == 0 then return end


	local viewport_x, viewport_y, viewport_w, viewport_h = fit_viewport(window_w, window_h)

	render.set_viewport(viewport_x, viewport_y, viewport_w, viewport_h)
	render.set_depth_mask(false)
	render.disable_state(render.STATE_DEPTH_TEST)
	render.disable_state(render.STATE_STENCIL_TEST)
	render.enable_state(render.STATE_BLEND)
	render.set_blend_func(render.BLEND_SRC_ALPHA, render.BLEND_ONE_MINUS_SRC_ALPHA)

	local cx = self.camera_pos.x
	local cy = self.camera_pos.y
	local view = vmath.matrix4_look_at(
		vmath.vector3(cx, cy, 1),
		vmath.vector3(cx, cy, 0),
		vmath.vector3(0, 1, 0))
	local proj = vmath.matrix4_orthographic(
		-DISPLAY_WIDTH / (2 * CAMERA_ZOOM), DISPLAY_WIDTH / (2 * CAMERA_ZOOM),
		-DISPLAY_HEIGHT / (2 * CAMERA_ZOOM), DISPLAY_HEIGHT / (2 * CAMERA_ZOOM),
		-1, 1)
	render.set_view(view)
	render.set_projection(proj)

	-- cable frustum: large padding so scaled cable sprites never get culled mid-swing
	local pad = 2000
	local cable_frustum = vmath.matrix4_orthographic(
		-DISPLAY_WIDTH / (2 * CAMERA_ZOOM) - pad, DISPLAY_WIDTH / (2 * CAMERA_ZOOM) + pad,
		-DISPLAY_HEIGHT / (2 * CAMERA_ZOOM) - pad, DISPLAY_HEIGHT / (2 * CAMERA_ZOOM) + pad,
		-1, 1) * view

	render.draw(self.bg_pred)
	render.draw(self.tile_pred)
	render.draw(self.cable_pred, { frustum = cable_frustum })
	render.draw(self.sprite_pred, { frustum = cable_frustum })
	render.draw(self.particle_pred)
	render.draw_debug3d()

	-- GUI pass: use actual window dimensions as coordinate space (matches Defold default)
	render.set_view(vmath.matrix4())
	render.set_projection(vmath.matrix4_orthographic(0, window_w, 0, window_h, -1, 1))
	render.set_viewport(0, 0, window_w, window_h)
	render.enable_state(render.STATE_STENCIL_TEST)
	render.draw(self.gui_pred)
	render.draw(self.text_pred)
	render.disable_state(render.STATE_STENCIL_TEST)
end

function on_message(self, message_id, message)
	if message_id == hash("clear_color") then
		self.clear_color = message.color
	elseif message_id == hash("set_camera_pos") then
		self.camera_pos = message.pos
	end
end
